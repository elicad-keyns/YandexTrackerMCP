# Protection for the public MCP endpoint. This is not a Yandex token.
MCP_API_KEY=replace-with-a-long-random-secret
MCP_PUBLIC_URL=https://tracker-mcp.example.com
MCP_HOST=0.0.0.0
MCP_PORT=8788
LOG_LEVEL=INFO

# yandex | mock. Use mock only for tests.
TRACKER_BACKEND=yandex

# OAuth for Yandex 360: OAuth token + X-Org-ID.
YANDEX_AUTH_TYPE=oauth
YANDEX_TRACKER_TOKEN=replace-with-yandex-oauth-token
YANDEX_ORG_ID=replace-with-organization-id
YANDEX_ORG_HEADER=X-Org-ID

# For Yandex Cloud use an IAM token and X-Cloud-Org-ID instead:
# YANDEX_AUTH_TYPE=iam
# YANDEX_ORG_HEADER=X-Cloud-Org-ID

YANDEX_DEFAULT_QUEUE=YOURQUEUE
YANDEX_TRACKER_API_URL=https://api.tracker.yandex.net/v3

# Day 18 scheduler and Telegram delivery.
SCHEDULER_DATABASE=data/scheduler.db
SCHEDULER_TIMEZONE=Europe/Moscow
TELEGRAM_BOT_SERVICE_URL=http://telegram-bot:8791
TELEGRAM_BOT_SERVICE_API_KEY=replace-with-another-long-random-secret
